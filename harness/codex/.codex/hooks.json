{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/aegis_session_start.py\"",
            "statusMessage": "Loading aegis session-start guidance"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/aegis_pre_tool_use.py\"",
            "timeout": 30,
            "statusMessage": "Checking aegis protected-file policy"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/aegis_stop_validate.py\"",
            "timeout": 120,
            "statusMessage": "Running aegis validation"
          }
        ]
      }
    ]
  }
}
